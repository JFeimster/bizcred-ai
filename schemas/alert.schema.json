{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alert",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["info", "warning", "error", "success"]
    },
    "message": { "type": "string" },
    "created_at": { "type": "string" },
    "read": { "type": "boolean" },
    "action_url": { "type": "string" },
    "action_text": { "type": "string" }
  },
  "required": ["id", "type", "message", "created_at", "read"]
}
