{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BusinessProfile",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "legal_name": { "type": "string" },
    "dba_name": { "type": "string" },
    "ein": { "type": "string" },
    "entity_type": { "type": "string" },
    "date_established": { "type": "string" },
    "state_of_incorporation": { "type": "string" },
    "address": {
      "type": "object",
      "properties": {
        "street": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" }
      },
      "required": ["street", "city", "state", "zip"]
    },
    "phone": { "type": "string" },
    "website": { "type": "string" },
    "industry": { "type": "string" },
    "naics_code": { "type": "string" }
  },
  "required": ["id", "legal_name", "entity_type", "address"]
}
