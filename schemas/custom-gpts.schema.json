{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CustomGpt",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "url": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["planning", "analysis", "funding", "legal", "other"]
    },
    "verification_status": {
      "type": "string",
      "enum": ["unverified", "needs_review", "verified", "deprecated"]
    }
  },
  "required": ["id", "name", "description", "url", "category", "verification_status"]
}
