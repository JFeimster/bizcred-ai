{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FundingTool",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["loan", "line_of_credit", "credit_card", "grant", "other"]
    },
    "provider": { "type": "string" },
    "max_amount": { "type": "number" },
    "min_credit_score": { "type": "number" },
    "min_months_in_business": { "type": "number" },
    "min_monthly_revenue": { "type": "number" },
    "requires_pg": { "type": "boolean" },
    "description": { "type": "string" },
    "verification_status": {
      "type": "string",
      "enum": ["unverified", "needs_review", "verified", "deprecated"]
    }
  },
  "required": ["id", "name", "type", "provider", "requires_pg", "description", "verification_status"]
}
