{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Roadmap",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "done", "skipped"]
          },
          "due_date": { "type": "string" },
          "completed_date": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "category": {
            "type": "string",
            "enum": ["setup", "credit_building", "funding", "compliance", "other"]
          }
        },
        "required": ["id", "title", "description", "status", "priority", "category"]
      }
    }
  },
  "required": ["id", "items"]
}
