{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bizcred-ai.local/schemas/tradeline.schema.json",
  "title": "Tradeline",
  "type": "object",
  "required": ["id", "vendorName", "accountType", "tier", "status", "reportsTo", "notes"],
  "properties": {
    "id": { "type": "string" },
    "vendorName": { "type": "string" },
    "accountType": { "type": "string" },
    "tier": { "type": "integer", "minimum": 1 },
    "status": { "type": "string" },
    "limitAmount": { "type": "number" },
    "balanceAmount": { "type": "number" },
    "reportsTo": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
