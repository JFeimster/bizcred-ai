{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tradeline",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "vendor_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "applied", "approved", "denied", "reporting", "closed"]
    },
    "credit_limit": { "type": "number" },
    "current_balance": { "type": "number" },
    "date_opened": { "type": "string" },
    "last_reported": { "type": "string" },
    "notes": { "type": "string" }
  },
  "required": ["id", "vendor_id", "status"]
}
