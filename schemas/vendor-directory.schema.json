{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vendor",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "tier": { "type": "number" },
    "category": { "type": "string" },
    "reports_to": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dnb_reporter": { "type": "boolean" },
    "terms": { "type": "string" },
    "requires_pg": { "type": "boolean" },
    "ein_only": { "type": "boolean" },
    "min_time_in_business_months": { "type": "number" },
    "approval_notes": { "type": "string" },
    "verification_status": {
      "type": "string",
      "enum": ["unverified", "needs_review", "verified", "deprecated"]
    }
  },
  "required": [
    "id", "name", "tier", "category", "reports_to", "dnb_reporter",
    "terms", "requires_pg", "ein_only", "min_time_in_business_months",
    "approval_notes", "verification_status"
  ]
}
